          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  DATE_FORMAT(i.date, \"%Y-%m-%d\") AS 'Date',\n  it.name AS 'Income type',\n  i.description AS 'Description',\n  i.value AS 'Amount'\nFROM income i\nINNER JOIN income_type it ON i.income_type_id = it.id\nINNER JOIN account aa ON aa.id = i.account_id\nLEFT JOIN spend s ON i.spend_id = s.id\nWHERE\n  $__timeFilter(i.date)\n  AND aa.name IN (${Account})\nORDER BY 1",
