          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  SUM(s.value - COALESCE(i.total_income, 0)) AS 'value'\nFROM spend s\nLEFT JOIN (\n  SELECT\n    spend_id,\n    SUM(value) AS total_income\n  FROM income\n  GROUP BY spend_id\n) i ON s.id = i.spend_id\nJOIN account aa ON aa.id = s.account_id\nJOIN category cc ON cc.id = s.category_id\nLEFT JOIN subcategory ss ON ss.id = s.subcategory_id\nLEFT JOIN `group` gg ON gg.id = s.group_id\nWHERE\n  $__timeFilter(s.date)\n  AND aa.name IN (${Account})\n  AND cc.name IN (${Category})\n  AND (\n    s.subcategory_id IS NULL\n    OR '${Subcategory:regex}' IN ('', '()')\n    OR (\n      ss.name REGEXP '^(${Subcategory:regex})$'\n      AND (\n        s.group_id IS NULL\n        OR '${Group:regex}' IN ('', '()') \n        OR gg.name REGEXP '^(${Group:regex})$'\n      )\n    )\n  )",
          "refId": "A",
          "sql": {
