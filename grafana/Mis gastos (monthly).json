          "rawSql": "SELECT\n  $__timeGroupAlias(s.date,'1M'),\n  COALESCE(gg.name, 'No group') AS name,\n  SUM(s.value) AS ''\nFROM (\n  SELECT\n    s.id,\n    s.date,\n    s.category_id,\n    s.subcategory_id,\n    s.group_id,\n    s.value - COALESCE(i.total_income, 0) AS value\n  FROM spend s\n  LEFT JOIN (\n    SELECT spend_id, SUM(value) AS total_income\n    FROM income\n    GROUP BY spend_id\n  ) i ON s.id = i.spend_id\n) s\nJOIN category cc ON cc.id = s.category_id\nLEFT JOIN subcategory ss ON ss.id = s.subcategory_id\nLEFT JOIN `group` gg ON gg.id = s.group_id\nWHERE\n  $__timeFilter(s.date)\n  AND cc.name IN (${Category})\n  AND (\n    s.subcategory_id IS NULL\n    OR (\n      ss.name IN (${Subcategory})\n      AND (\n        s.group_id IS NULL\n        OR gg.name IN (${Group})\n      )\n    )\n  )\nGROUP BY 1, COALESCE(gg.name, 'No group')\nORDER BY 1, COALESCE(gg.name, 'No group')",
          "refId": "A",
