          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(s.date,'1M'),\n  COALESCE(ss.name, 'No subcategory') AS name,\n  SUM(s.value) AS ''\nFROM (\n  SELECT\n    s.date,\n    s.category_id,\n    s.subcategory_id,\n    CASE WHEN i.value IS NOT NULL THEN AVG(s.value) - SUM(i.value) ELSE AVG(s.value) END AS value\n    FROM spend s\n    LEFT JOIN income i ON s.id = i.spend_id\n    LEFT JOIN subcategory ss ON ss.id = s.subcategory_id\n    JOIN category cc ON cc.id = s.category_id\n    WHERE $__timeFilter(s.date) AND cc.name IN (${Category}) AND (s.subcategory_id IS NULL OR ss.name IN (${Subcategory}))\n    GROUP BY s.id) s\nLEFT JOIN subcategory ss ON s.subcategory_id = ss.id\nGROUP BY 1, COALESCE(ss.name, 'No Subcategory')\nORDER BY 1\n",
