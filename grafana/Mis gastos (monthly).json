        {
          "dataset": "misgastos",
          "datasource": {
            "type": "mysql",
            "uid": "ffjwtjbqvpy4ge"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  DATE_FORMAT(s.date, '%Y-%m-01') AS 'Month',\n  cc.name AS name,\n  SUM(s.value - COALESCE(i.total_income, 0)) AS ''\nFROM spend s\nLEFT JOIN (\n  SELECT\n    spend_id,\n    SUM(value) AS total_income\n  FROM income\n  GROUP BY spend_id\n) i ON s.id = i.spend_id\nJOIN category cc ON cc.id = s.category_id\nLEFT JOIN subcategory ss ON ss.id = s.subcategory_id\nLEFT JOIN `group` gg ON gg.id = s.group_id\nWHERE\n  $__timeFilter(s.date)\n  AND cc.name IN (${Category})\n  AND (\n    s.subcategory_id IS NULL\n    OR (\n      ss.name IN (${Subcategory})\n      AND (\n        s.group_id IS NULL\n        OR gg.name IN (${Group})\n      )\n    )\n  )\nGROUP BY 1, cc.name\nORDER BY 1, cc.name",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [
                  {
                    "name": "date",
                    "type": "functionParameter"
                  }
                ],
