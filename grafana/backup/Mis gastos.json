          "rawQuery": true,
          "rawSql": "SELECT\n\taccount_name AS metric,\n\tSUM(s.value) AS value\nFROM (\n\tSELECT\n\t\ta.name AS account_name,\n\t\tCASE WHEN i.value IS NOT NULL THEN AVG(s.value) - SUM(i.value) ELSE AVG(s.value) END AS value\n\tFROM spend s\n\tLEFT JOIN income i ON s.id = i.spend_id\n\tLEFT JOIN subcategory ss ON ss.id = s.subcategory_id\n\tJOIN account a ON a.id = s.account_id\n\tJOIN category c ON c.id = s.category_id\n  WHERE $__timeFilter(s.date) AND c.name IN (${Category}) AND (s.subcategory_id IS NULL OR ss.name IN (${Subcategory}))\n\tGROUP BY s.id ) s\nGROUP BY metric\n",
